{
  "name": "@agentdeck/bridge",
  "version": "0.2.3",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/puritysb/AgentDeck.git",
    "directory": "bridge"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "assets/fonts",
    "assets/fm-helper",
    "fm-helper",
    "scripts/build-fm-helper.mjs"
  ],
  "main": "./dist/index.js",
  "bin": {
    "agentdeck": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:fm-helper": "node scripts/build-fm-helper.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js claude"
  },
  "dependencies": {
    "@agentdeck/hooks": "workspace:*",
    "@agentdeck/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.111.0",
    "bonjour-service": "^1.3.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "strip-ansi": "^7.2.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "@picovoice/pvrecorder-node": "^1.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.9.0",
    "node-hid": "^3.3.0",
    "node-pty": "^1.1.0"
  },
  "compatibleClaudeCode": ">=2.1.50",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
