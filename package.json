{
  "name": "agentdeck",
  "version": "0.2.3",
  "private": true,
  "description": "Stream Deck+ controller for Claude Code CLI",
  "scripts": {
    "build": "pnpm --filter @agentdeck/shared build && pnpm --filter=!@agentdeck/shared -r build",
    "dev": "pnpm -r --parallel dev",
    "demo": "node scripts/render-creature-simulator.mjs && node scripts/render-esp32-sim-frames.mjs && npx --yes vite tools/creature-simulator",
    "demo:build": "node scripts/render-creature-simulator.mjs && node scripts/render-esp32-sim-frames.mjs && vite build tools/creature-simulator --base=/AgentDeck/demo/ --outDir ../../dist/demo --emptyOutDir && cp tools/creature-simulator/sim-data.js dist/demo/sim-data.js && cp -R tools/creature-simulator/sim-frames dist/demo/sim-frames",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-creature-glyphs": "node scripts/generate-creature-glyphs.mjs",
    "generate-micro-glyphs": "node scripts/generate-micro-glyphs.mjs",
    "generate-protocol": "bash scripts/generate-protocol.sh",
    "generate-terrarium-rules": "node scripts/generate-terrarium-rules.mjs",
    "verify-version": "node scripts/verify-version-sync.mjs",
    "check-preview-sync": "node scripts/check-preview-mirror-sync.mjs",
    "design-system:build": "node scripts/build-design-system-viewer.mjs",
    "design-system:check": "node scripts/build-design-system-viewer.mjs --check",
    "package": "bash scripts/package-plugin.sh",
    "setup": "bash scripts/install.sh",
    "test": "vitest run",
    "test:report": "bash scripts/test-report.sh",
    "test:android": "bash scripts/test-report.sh --android",
    "test:html": "pnpm vitest run --coverage && python3 scripts/generate-html-report.py && open coverage/test-report/index.html",
    "esp32:sim": "bash esp32/sim/render.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.5.0 <12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "quicktype": "^23.2.6",
    "sharp": "^0.34.5",
    "ts-json-schema-generator": "^2.9.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
