node_modules/
dist/
*.js.map
*.tsbuildinfo
**/*.sdPlugin/bin/
**/*.sdPlugin/logs/
.claude/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Xcode user-specific state (window/editor state, breakpoints, schemes)
**/xcuserdata/
*.xcuserstate

# Logs
*.log

# Temp
*.tmp
test-*.js

# Media (use docs/media/ for committed images)
/screenshot*.png
/IMG_*
/*.gif
/*.mov
/*.webp
assets/videos/
assets/screenshots/

# Runtime
compatibility.json

# Generated code (regenerate via: bash scripts/generate-protocol.sh)
# Track generated/protocol/ so CI can catch drift; other subdirs stay ignored.
generated/*
!generated/protocol/

# Coverage
coverage/

# Android signing
android/signing.properties
android/*.jks

# Apple signing & certificates
*.p12
*.cer
*.mobileprovision
*.provisionprofile
*.certSigningRequest
AuthKey_*.p8
private_keys/

# Build artifacts
apple/build/
*.profraw
.zig-cache/
.zig-global-cache/

# Python bytecode
__pycache__/
*.pyc

# ESP32 robot test results
esp32/robot/results/

# Experimental scratch files
scratch-*.ts
scratch-*.js

# zkswe hardware recon — cross-compiled ARM/Mach-O binaries rebuilt via build.sh
zkswe/agent-archive/*
!zkswe/agent-archive/build.sh
!zkswe/agent-archive/*.sh
!zkswe/agent-archive/lib/
zkswe/recon/*.dylib
zkswe/recon/*.so

# Creature simulator generated data (rebuilt by scripts/render-creature-simulator.mjs)
tools/creature-simulator/sim-data.js
