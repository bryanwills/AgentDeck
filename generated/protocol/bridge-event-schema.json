{
  "$ref": "#/definitions/BridgeEvent",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AgentCapabilities": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string"
        },
        "hasApiUsage": {
          "description": "OAuth-based API usage tracking",
          "type": "boolean"
        },
        "hasDiffReview": {
          "description": "Diff review UI (view/apply/deny)",
          "type": "boolean"
        },
        "hasModeSwitching": {
          "description": "Plan/AcceptEdits/Default mode switching",
          "type": "boolean"
        },
        "hasModelCatalog": {
          "description": "CLI-based model catalog (openclaw models list)",
          "type": "boolean"
        },
        "hasNavigablePrompts": {
          "description": "Arrow-key navigable prompts",
          "type": "boolean"
        },
        "hasOptionLists": {
          "description": "Numbered option lists with arrow navigation",
          "type": "boolean"
        },
        "hasSuggestedPrompts": {
          "description": "Ghost text suggested prompts",
          "type": "boolean"
        },
        "hasTerminal": {
          "description": "PTY terminal attachment (stdin/stdout proxy)",
          "type": "boolean"
        },
        "type": {
          "$ref": "#/definitions/AgentType"
        }
      },
      "required": [
        "type",
        "displayName",
        "hasTerminal",
        "hasModeSwitching",
        "hasDiffReview",
        "hasOptionLists",
        "hasNavigablePrompts",
        "hasSuggestedPrompts",
        "hasApiUsage",
        "hasModelCatalog"
      ],
      "type": "object"
    },
    "AgentType": {
      "enum": [
        "claude-code",
        "openclaw",
        "codex-cli",
        "opencode",
        "monitor"
      ],
      "type": "string"
    },
    "AntigravityStatusInfo": {
      "additionalProperties": false,
      "properties": {
        "availableCredits": {
          "type": "number"
        },
        "minimumCreditAmountForUsage": {
          "type": "number"
        },
        "planName": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "ApmeEvalEvent": {
      "additionalProperties": false,
      "description": "Bridge → clients — fires when a run completes evaluation (layer 1 or 2).",
      "properties": {
        "run": {
          "$ref": "#/definitions/ApmeRunSummary"
        },
        "type": {
          "const": "apme_eval",
          "type": "string"
        }
      },
      "required": [
        "type",
        "run"
      ],
      "type": "object"
    },
    "ApmeEvalRow": {
      "additionalProperties": false,
      "description": "A single evaluation score on a completed run.",
      "properties": {
        "createdAt": {
          "type": "number"
        },
        "judgeModel": {
          "type": "string"
        },
        "layer": {
          "enum": [
            "deterministic",
            "llm_judge",
            "vibe",
            "turn_judge"
          ],
          "type": "string"
        },
        "metric": {
          "type": "string"
        },
        "rubricVer": {
          "type": "number"
        },
        "score": {
          "type": "number"
        }
      },
      "required": [
        "layer",
        "metric",
        "score",
        "createdAt"
      ],
      "type": "object"
    },
    "ApmeModelScorecard": {
      "additionalProperties": false,
      "properties": {
        "agentType": {
          "$ref": "#/definitions/AgentType"
        },
        "avgOverall": {
          "type": "number"
        },
        "avgTestsPass": {
          "type": "number"
        },
        "costPerQuality": {
          "type": "number"
        },
        "modelId": {
          "type": "string"
        },
        "runs": {
          "type": "number"
        },
        "totalCost": {
          "type": "number"
        }
      },
      "required": [
        "agentType",
        "modelId",
        "runs"
      ],
      "type": "object"
    },
    "ApmeRecommendation": {
      "additionalProperties": false,
      "properties": {
        "agentType": {
          "$ref": "#/definitions/AgentType"
        },
        "confidence": {
          "type": "number"
        },
        "expectedCostUsd": {
          "type": "number"
        },
        "expectedScore": {
          "type": "number"
        },
        "modelId": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
