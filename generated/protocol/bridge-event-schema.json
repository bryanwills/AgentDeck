      },
      "required": [
        "type",
        "candidates"
      ],
      "type": "object"
    },
    "ApmeRunSummary": {
      "additionalProperties": false,
      "description": "A run that has finished evaluation.",
      "properties": {
        "agentType": {
          "$ref": "#/definitions/AgentType"
        },
        "compositeScore": {
          "type": "number"
        },
        "costUsd": {
          "type": "number"
        },
        "endedAt": {
          "type": "number"
        },
        "evals": {
          "items": {
            "$ref": "#/definitions/ApmeEvalRow"
          },
          "type": "array"
        },
        "exitCode": {
          "type": "number"
        },
        "inputTokens": {
          "type": "number"
        },
        "modelId": {
          "type": "string"
        },
        "outcome": {
          "enum": [
            "committed",
            "abandoned",
            "iterated",
            "ab_winner",
            "ab_loser",
            "interrupted",
            "exploratory",
            "pending"
          ],
          "type": "string"
        },
        "outputTokens": {
          "type": "number"
        },
        "overallScore": {
          "type": "number"
        },
        "projectName": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "startedAt": {
          "type": "number"
        },
        "taskCategory": {
          "type": "string"
        },
        "taskPrompt": {
          "type": "string"
        }
      },
      "required": [
        "runId",
        "sessionId",
        "agentType",
        "startedAt",
        "evals"
      ],
      "type": "object"
    },
    "ApmeScorecardEvent": {
      "additionalProperties": false,
      "description": "Bridge → clients — scorecard refresh (broadcast after eval completes or on demand).",
