        "status": {
          "enum": [
            "pending",
            "approved",
            "denied"
          ],
          "type": "string"
        },
        "summaryKind": {
          "description": "How the row's `raw` summary was produced. Lets clients decide whether the detail pane is worth showing — when `'none'`, detail is just the unfiltered response that the heuristic couldn't summarize, and showing it duplicates content rather than adding value.   - `'llm'`     : LLM-summarized (clean, short, distinct from detail)   - `'heuristic'`: topic-hint extracted from response or prompt   - `'none'`    : last-resort fallback (literal \"Completed\", bare tool name, etc.)   - `'progress'`: non-terminal assistant status update (work still running)",
          "enum": [
            "llm",
            "heuristic",
            "none",
            "progress"
          ],
          "type": "string"
        },
        "taskCategory": {
          "type": "string"
        },
        "taskId": {
          "description": "APME task id. Set on task_start/task_end and on every turn entry inside the task scope.",
          "type": "string"
        },
        "taskOutcome": {
          "type": "string"
        },
        "taskScore": {
          "description": "Per-task evaluation result, attached when the task_judge resolves (always AFTER the initial task_end emit — clients upsert the existing row by (type='task_end', taskId) and merge these four fields).\n\n  - `taskScore`   : 0..1 composite (matches `tasks.composite_score`)   - `taskOutcome` : terminal outcome string from `bridge/src/apme/outcome.ts`     (`'committed' | 'abandoned' | 'iterated' | 'ab_winner' | 'ab_loser'     | 'interrupted' | 'exploratory' | 'pending'`). UIs collapse into     three visual classes — success / fail / partial / pending — and pick     the badge color via design-system status tokens.   - `taskCategory`: task_rollup category ('general' | 'conversation' | …)   - `taskSummary` : one-line judge summary",
          "type": "number"
        },
        "taskSummary": {
          "type": "string"
        },
        "ts": {
          "type": "number"
        },
        "type": {
          "$ref": "#/definitions/TimelineEntryType"
        }
      },
      "required": [
        "ts",
        "type",
        "raw"
      ],
      "type": "object"
    },
