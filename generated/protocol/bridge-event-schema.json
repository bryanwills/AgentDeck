      "required": [
        "modelId",
        "agentType",
        "expectedScore",
        "expectedCostUsd",
        "confidence",
        "rationale"
      ],
      "type": "object"
    },
    "ApmeRecommendationEvent": {
      "additionalProperties": false,
      "description": "Bridge → clients — model recommendation for the next task (on-demand / context-aware).",
