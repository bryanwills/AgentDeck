        "scorecards": {
          "items": {
            "$ref": "#/definitions/ApmeModelScorecard"
          },
          "type": "array"
        },
        "type": {
          "const": "apme_scorecard",
          "type": "string"
        }
      },
      "required": [
        "type",
        "scorecards"
      ],
      "type": "object"
    },
    "BillingType": {
      "enum": [
        "subscription",
        "api",
        "unknown"
      ],
      "type": "string"
    },
    "BridgeEvent": {
      "anyOf": [
        {
          "$ref": "#/definitions/StateUpdateEvent"
        },
        {
          "$ref": "#/definitions/PromptOptionsEvent"
        },
        {
          "$ref": "#/definitions/UsageEvent"
        },
        {
          "$ref": "#/definitions/ConnectionEvent"
        },
        {
          "$ref": "#/definitions/UserPromptEvent"
        },
        {
          "$ref": "#/definitions/VoiceStateEvent"
        },
        {
          "$ref": "#/definitions/VoiceAssistantStateEvent"
        },
        {
          "$ref": "#/definitions/WakeWordDetectedEvent"
        },
        {
          "$ref": "#/definitions/DisplayStateEvent"
        },
        {
          "$ref": "#/definitions/SessionsListEvent"
        },
        {
          "$ref": "#/definitions/EncoderStateEvent"
        },
        {
          "$ref": "#/definitions/DeckSlotMapEvent"
        },
        {
          "$ref": "#/definitions/ButtonStateEvent"
        },
        {
          "$ref": "#/definitions/TimelineEventMsg"
        },
        {
          "$ref": "#/definitions/TimelineHistoryMsg"
        },
        {
          "$ref": "#/definitions/ApmeEvalEvent"
        },
        {
          "$ref": "#/definitions/ApmeScorecardEvent"
        },
        {
          "$ref": "#/definitions/ApmeRecommendationEvent"
        }
      ]
    },
