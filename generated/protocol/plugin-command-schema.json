{
  "$ref": "#/definitions/PluginCommand",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ApmeRecommendCommand": {
      "additionalProperties": false,
      "description": "Ask bridge/daemon for model recommendation given a task context.",
      "properties": {
        "budgetUsd": {
          "type": "number"
        },
        "latencyBudgetMs": {
          "type": "number"
        },
        "preferLocal": {
          "type": "boolean"
        },
        "taskKind": {
          "type": "string"
        },
        "type": {
          "const": "apme_recommend",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ApmeVibeFeedbackCommand": {
      "additionalProperties": false,
      "description": "APME vibe check — user approves or rejects a completed run's output quality.",
      "properties": {
        "note": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "type": {
          "const": "apme_vibe",
          "type": "string"
        },
        "verdict": {
          "enum": [
            "approve",
            "reject",
            "neutral"
          ],
          "type": "string"
        }
      },
      "required": [
        "type",
        "runId",
        "verdict"
      ],
      "type": "object"
    },
    "ClearSessionFocusCommand": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "clear_session_focus",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ClientRegisterCommand": {
      "additionalProperties": false,
      "description": "Self-announcement from a rich UI client (Elgato Stream Deck plugin, a future Android companion app, etc.) so the daemon can surface the hardware under its rightful Downstream row instead of treating every WS connection as an anonymous dashboard viewer. Sent once per connect, immediately after the WebSocket opens. Daemon wipes the cached entry when the WS connection closes.",
      "properties": {
        "clientLabel": {
          "description": "Human-readable label for the surface (appears verbatim in diagnostics).",
          "type": "string"
        },
        "clientType": {
          "description": "Short stable id — \"streamdeck-plugin\", \"android-companion\", etc.",
          "type": "string"
        },
        "devices": {
          "description": "Physical device roster this client is driving, if any.",
          "items": {
            "additionalProperties": false,
            "properties": {
              "columns": {
                "type": "number"
              },
              "family": {
                "description": "\"streamdeck\" | \"streamdeckplus\" | \"streamdeckmini\" | ... — free-form.",
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "rows": {
                "type": "number"
              }
            },
            "required": [
              "id",
              "name"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "const": "client_register",
          "type": "string"
        }
      },
      "required": [
        "type",
        "clientType"
      ],
      "type": "object"
    },
    "DiagCommand": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "dump",
            "analyze"
          ],
          "type": "string"
        },
        "type": {
          "const": "diag",
          "type": "string"
        }
      },
      "required": [
        "type",
        "action"
      ],
      "type": "object"
    },
    "EscapeCommand": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "escape",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "Esp32OtaAckCommand": {
      "additionalProperties": false,
      "properties": {
        "offset": {
          "type": "number"
        },
        "otaId": {
          "type": "string"
        },
        "seq": {
          "type": "number"
        },
        "stage": {
          "enum": [
            "begin",
            "chunk",
            "end",
            "abort"
          ],
          "type": "string"
        },
        "type": {
          "const": "esp32_ota_ack",
          "type": "string"
        },
        "written": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "otaId",
        "stage"
      ],
      "type": "object"
    },
    "Esp32OtaErrorCommand": {
      "additionalProperties": false,
      "properties": {
        "error": {
          "type": "string"
        },
        "otaId": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "type": {
          "const": "esp32_ota_error",
          "type": "string"
        }
      },
      "required": [
        "type",
        "error"
      ],
      "type": "object"
    },
    "FocusSessionCommand": {
      "additionalProperties": false,
      "properties": {
        "sessionId": {
          "type": "string"
        },
        "type": {
          "const": "focus_session",
          "type": "string"
        }
      },
      "required": [
        "type",
        "sessionId"
      ],
      "type": "object"
    },
    "InterruptCommand": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "interrupt",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "NavigateOptionCommand": {
      "additionalProperties": false,
      "properties": {
        "direction": {
          "enum": [
            "up",
            "down"
          ],
          "type": "string"
        },
        "type": {
          "const": "navigate_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "direction"
      ],
      "type": "object"
    },
    "PermissionDecisionCommand": {
      "additionalProperties": false,
      "description": "Device approval decision for a gated PreToolUse permission request (observed sessions). The daemon holds the hook's HTTP response open keyed by `requestId`; this command resolves it into a Claude Code permission decision. See bridge/src/permission-resolver.ts.",
      "properties": {
        "decision": {
          "enum": [
            "allow",
            "deny"
          ],
          "type": "string"
        },
        "requestId": {
          "type": "string"
        },
        "type": {
          "const": "permission_decision",
          "type": "string"
        }
      },
      "required": [
        "type",
        "requestId",
        "decision"
      ],
      "type": "object"
    },
    "PluginCommand": {
      "anyOf": [
        {
          "$ref": "#/definitions/ResponseCommand"
        },
        {
          "$ref": "#/definitions/SelectOptionCommand"
        },
        {
          "$ref": "#/definitions/NavigateOptionCommand"
        },
        {
          "$ref": "#/definitions/SendPromptCommand"
        },
        {
          "$ref": "#/definitions/SwitchModeCommand"
        },
        {
          "$ref": "#/definitions/InterruptCommand"
        },
        {
          "$ref": "#/definitions/EscapeCommand"
        },
        {
          "$ref": "#/definitions/VoiceCommand"
        },
        {
          "$ref": "#/definitions/QueryUsageCommand"
        },
        {
          "$ref": "#/definitions/QuerySessionTimelineCommand"
        },
        {
          "$ref": "#/definitions/DiagCommand"
        },
        {
          "$ref": "#/definitions/UtilityCommand"
        },
        {
          "$ref": "#/definitions/SwitchAgentCommand"
        },
        {
          "$ref": "#/definitions/FocusSessionCommand"
        },
        {
          "$ref": "#/definitions/ClearSessionFocusCommand"
        },
        {
          "$ref": "#/definitions/SessionCommand"
        },
        {
          "$ref": "#/definitions/ClientRegisterCommand"
        },
        {
          "$ref": "#/definitions/ApmeVibeFeedbackCommand"
        },
        {
          "$ref": "#/definitions/ApmeRecommendCommand"
        },
        {
          "$ref": "#/definitions/PermissionDecisionCommand"
        },
        {
          "$ref": "#/definitions/Esp32OtaAckCommand"
        },
        {
          "$ref": "#/definitions/Esp32OtaErrorCommand"
        }
      ]
    },
    "QuerySessionTimelineCommand": {
      "additionalProperties": false,
      "description": "Request a session's recent timeline. The daemon replies (to the requester only) with a `timeline_history` carrying that session's entries. Lets a device that connects mid-session fill its per-session Detail view.",
      "properties": {
        "sessionId": {
          "type": "string"
        },
        "since": {
          "description": "Optional epoch-ms lower bound; omit for the full retained history.",
          "type": "number"
        },
        "type": {
          "const": "query_session_timeline",
          "type": "string"
        }
      },
      "required": [
        "type",
        "sessionId"
      ],
      "type": "object"
    },
    "QueryUsageCommand": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "query_usage",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ResponseCommand": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "respond",
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "type": "object"
    },
    "SelectOptionCommand": {
      "additionalProperties": false,
      "properties": {
        "index": {
          "type": "number"
        },
        "sessionId": {
          "type": "string"
        },
        "type": {
          "const": "select_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "index"
      ],
      "type": "object"
    },
    "SendPromptCommand": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "type": {
          "const": "send_prompt",
          "type": "string"
        }
      },
      "required": [
        "type",
        "text"
      ],
      "type": "object"
    },
    "SessionCommand": {
      "additionalProperties": false,
      "description": "Session-scoped command — daemon forwards the inner command to the specified session's bridge. Enables direct control of a specific session from any client (MenuBarExtra, Dashboard, etc.)",
      "properties": {
        "command": {
          "additionalProperties": {},
          "properties": {
            "type": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        "sessionId": {
          "type": "string"
        },
        "type": {
          "const": "session_command",
          "type": "string"
        }
      },
      "required": [
        "type",
        "sessionId",
        "command"
      ],
      "type": "object"
    },
    "SwitchAgentCommand": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "enum": [
            "openclaw",
            "claude-code"
          ],
          "type": "string"
        },
        "type": {
          "const": "switch_agent",
          "type": "string"
        }
      },
      "required": [
        "type",
        "agent"
      ],
      "type": "object"
    },
    "SwitchModeCommand": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "plan",
            "acceptEdits",
            "default"
          ],
          "type": "string"
        },
        "type": {
          "const": "switch_mode",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "UtilityCommand": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "adjust_volume",
            "toggle_mute",
            "adjust_brightness",
            "media_play_pause",
            "media_next",
            "media_prev"
          ],
          "type": "string"
        },
        "type": {
          "const": "utility",
          "type": "string"
        },
        "value": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "action"
      ],
      "type": "object"
    },
    "VoiceCommand": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "start",
            "stop",
            "cancel"
          ],
          "type": "string"
        },
        "type": {
          "const": "voice",
          "type": "string"
        }
      },
      "required": [
        "type",
        "action"
      ],
      "type": "object"
    }
  }
}

